      "page": "/admin/products/[id]/edit",
      "regex": "^/admin/products/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/products/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/orders/[id]",
      "regex": "^/orders/([^/]+?)(?:/)?$",
